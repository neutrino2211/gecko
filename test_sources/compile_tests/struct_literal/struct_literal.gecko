// spec: spec/types.md, spec/functions.md, spec/classes.md, spec/modules.md, spec/control-flow.md

@packed
class MultibootHeader {
    let magic: uint32
    let flags: uint32
    let checksum: uint32
}

external func main(): int32 {
    let header: MultibootHeader = MultibootHeader {
        magic: 0x1BADB002,
        flags: 0x00,
        checksum: 0xE4524FFE
    }

    return 0
}
