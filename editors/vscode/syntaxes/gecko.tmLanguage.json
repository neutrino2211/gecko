{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Gecko",
  "scopeName": "source.gecko",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#attributes" },
    { "include": "#intrinsics" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.documentation.gecko",
          "match": "///.*$"
        },
        {
          "name": "comment.line.double-slash.gecko",
          "match": "//.*$"
        },
        {
          "name": "comment.block.gecko",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            {
              "include": "#comments"
            }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.gecko",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.gecko",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "meta.attribute.gecko",
          "match": "(@)(\\w+)(?:\\s*(\\()([^)]*)(\\)))?",
          "captures": {
            "1": { "name": "punctuation.definition.attribute.gecko" },
            "2": { "name": "entity.other.attribute-name.gecko" },
            "3": { "name": "punctuation.section.arguments.begin.gecko" },
            "4": { "name": "string.quoted.double.gecko" },
            "5": { "name": "punctuation.section.arguments.end.gecko" }
          }
        }
      ]
    },
    "intrinsics": {
      "patterns": [
        {
          "name": "meta.intrinsic.gecko",
          "match": "(@)(deref|write_volatile|is_null|size_of|align_of)\\b",
          "captures": {
            "1": { "name": "punctuation.definition.intrinsic.gecko" },
            "2": { "name": "support.function.builtin.gecko" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.gecko",
          "match": "\\b(if|else|for|while|return|break|continue|of|in)\\b"
        },
        {
          "name": "keyword.declaration.gecko",
          "match": "\\b(package|import|cimport|use|withlibrary|withobject)\\b"
        },
        {
          "name": "keyword.other.gecko",
          "match": "\\b(declare|external|variardic|default)\\b"
        },
        {
          "name": "storage.type.gecko",
          "match": "\\b(class|trait|impl|enum|func|type)\\b"
        },
        {
          "name": "storage.modifier.gecko",
          "match": "\\b(let|const|public|private|protected|volatile)\\b"
        },
        {
          "name": "keyword.operator.cast.gecko",
          "match": "\\b(as|is)\\b"
        },
        {
          "name": "keyword.other.asm.gecko",
          "match": "\\b(asm)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.gecko",
          "match": "\\b(int|int8|int16|int32|int64|uint|uint8|uint16|uint32|uint64|float32|float64|bool|string|void)\\b"
        },
        {
          "name": "entity.name.type.gecko",
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.gecko",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.gecko",
          "match": "\\b(nil)\\b"
        },
        {
          "name": "variable.language.self.gecko",
          "match": "\\b(self)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.gecko",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.binary.gecko",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.octal.gecko",
          "match": "\\b0[oO][0-7]+\\b"
        },
        {
          "name": "constant.numeric.float.gecko",
          "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.gecko",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.gecko",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.gecko",
          "match": "(\\|\\||&&|!)"
        },
        {
          "name": "keyword.operator.bitwise.gecko",
          "match": "(>>>|<<<|>>|<<|\\||\\^|&)"
        },
        {
          "name": "keyword.operator.arithmetic.gecko",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.assignment.gecko",
          "match": "="
        },
        {
          "name": "keyword.operator.static-access.gecko",
          "match": "::"
        },
        {
          "name": "keyword.operator.address.gecko",
          "match": "&(?=[a-zA-Z_])"
        },
        {
          "name": "keyword.operator.pointer.gecko",
          "match": "\\*(?=[a-zA-Z_])"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.definition.gecko",
          "match": "\\b(func)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?:<|\\()",
          "captures": {
            "1": { "name": "storage.type.function.gecko" },
            "2": { "name": "entity.name.function.gecko" }
          }
        },
        {
          "name": "meta.function.call.static.gecko",
          "match": "([A-Z][a-zA-Z0-9_]*)\\s*(::)\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?:<|\\()",
          "captures": {
            "1": { "name": "entity.name.type.gecko" },
            "2": { "name": "keyword.operator.static-access.gecko" },
            "3": { "name": "entity.name.function.gecko" }
          }
        },
        {
          "name": "meta.function.call.gecko",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=<[^>]*>\\s*\\(|\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.gecko" }
          }
        },
        {
          "name": "meta.method.call.gecko",
          "match": "(\\.)([a-z_][a-zA-Z0-9_]*)\\s*(?=<[^>]*>\\s*\\(|\\()",
          "captures": {
            "1": { "name": "punctuation.accessor.gecko" },
            "2": { "name": "entity.name.function.member.gecko" }
          }
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.gecko",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
