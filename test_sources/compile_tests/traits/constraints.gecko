package constraints

trait Addable {
    func add(self, other: int): int
}

class Counter {
    let value: int
}

impl Addable for Counter {
    func add(self, other: int): int {
        return self.value + other
    }
}

func double<T is Addable>(item: T): int {
    return item.add(item.add(0))
}

external func main(): int32 {
    let c: Counter
    c.value = 21

    let result: int = double<Counter>(c)

    return result
}
