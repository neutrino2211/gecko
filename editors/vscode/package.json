{
  "name": "gecko-lang",
  "displayName": "Gecko",
  "description": "Syntax highlighting for the Gecko programming language",
  "version": "0.1.0",
  "publisher": "neutrino2211",
  "repository": {
    "type": "git",
    "url": "https://github.com/neutrino2211/gecko"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "gecko",
        "aliases": [
          "Gecko",
          "gecko"
        ],
        "extensions": [
          ".gecko"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/gecko.png",
          "dark": "./icons/gecko.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "gecko",
        "scopeName": "source.gecko",
        "path": "./syntaxes/gecko.tmLanguage.json"
      }
    ]
  }
}
