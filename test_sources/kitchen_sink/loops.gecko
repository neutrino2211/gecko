// spec: spec/types.md, spec/functions.md, spec/modules.md, spec/control-flow.md

package main

declare external variardic func printf(format: string): int

func main() {
  let counter: int = 0

  // Simple while-style loop
  for counter != 3 {
    printf(&"Loop iteration\n")
    counter = counter
  }

  printf(&"Done!\n")
}
