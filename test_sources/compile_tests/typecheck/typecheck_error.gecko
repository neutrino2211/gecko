package typecheck

func add(a: int, b: int): int {
    return a + b
}

func test_wrong_type(): void {
    // This should error - passing string to int parameter
    let result: int = add("hello", 5)
}

func test_reassign_const(): void {
    // This should error - reassigning a const
    const x: int = 10
    x = 20
}

func test_wrong_assign(): void {
    // This should error - assigning string to int variable
    let x: int = 10
    x = "hello"
}
