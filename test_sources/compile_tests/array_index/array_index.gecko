// Test array indexing for both reading and writing

// Test reading and writing to a volatile pointer (VGA buffer example)
func vga_test(): void {
    // Create a volatile pointer to uint16 (VGA buffer at 0xB8000 = 753664)
    let vga: uint16 volatile* = 753664 as uint16 volatile*

    // Write to VGA buffer using array indexing
    vga[0] = 3905  // 0x0F41 = white 'A' on black
    vga[1] = 3906  // 0x0F42 = white 'B' on black

    // Read from VGA buffer using array indexing
    let first: uint16 = vga[0]
    let second: uint16 = vga[1]
}

// Test with non-volatile pointer
func simple_array_test(): void {
    let ptr: uint32* = 4096 as uint32*

    // Write to array
    ptr[0] = 100
    ptr[1] = 200

    // Read from array
    let val: uint32 = ptr[0]
}
