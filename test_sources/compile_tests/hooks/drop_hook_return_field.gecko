// spec: spec/types.md, spec/functions.md, spec/traits.md, spec/modules.md, spec/control-flow.md, spec/attributes.md

package main

let dropped: int32 = 0

@drop_hook(.drop)
trait Drop {
    func drop(self): void
}

class Resource {
    let value: int32
}

impl Drop for Resource {
    func drop(self): void {
        dropped = dropped + 1
    }
}

func make_value(): int32 {
    let r: Resource = Resource { value: 42 }
    return r.value
}

external func main(): int32 {
    let v: int32 = make_value()
    return v + dropped
}
