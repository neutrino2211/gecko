package builtin_traits

class Data {
    let x: int
    let y: int
}

func process_safe(d: Data*!): int {
    let always_false: int = 0
    if (d.is_null()) {
        always_false = 100
    }
    return d.x + d.y + always_false
}

external func main(): int32 {
    let d: Data
    d.x = 15
    d.y = 25

    let safe_ptr: Data*! = &d

    return process_safe(safe_ptr)
}
