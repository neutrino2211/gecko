package main

class Point {
    let x: int32
    let y: int32

    func sum(self): int32 {
        return self.x + self.y
    }
}

impl Point {
    func sum(self): int32 {
        return self.x * self.y
    }
}

external func main(): int32 {
    let p: Point = Point { x: 10, y: 25 }
    return p.sum()
}
