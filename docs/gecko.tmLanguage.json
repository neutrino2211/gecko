{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "gecko",
  "scopeName": "source.gecko",
  "fileTypes": ["gecko"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#attributes" },
    { "include": "#intrinsics" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.gecko",
          "match": "//.*$"
        },
        {
          "name": "comment.block.gecko",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.gecko",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.gecko",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.gecko",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.gecko",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.gecko",
          "match": "\\b0[xX][0-9a-fA-F_]+\\b"
        },
        {
          "name": "constant.numeric.binary.gecko",
          "match": "\\b0[bB][01_]+\\b"
        },
        {
          "name": "constant.numeric.octal.gecko",
          "match": "\\b0[oO][0-7_]+\\b"
        },
        {
          "name": "constant.numeric.float.gecko",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9_]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.gecko",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.gecko",
          "match": "\\b(if|else|while|for|in|return|break|continue|match)\\b"
        },
        {
          "name": "keyword.declaration.gecko",
          "match": "\\b(func|class|trait|enum|impl|package|import|use|cimport|withobject|withlibrary)\\b"
        },
        {
          "name": "keyword.modifier.gecko",
          "match": "\\b(public|private|external|declare|variardic|const|let|volatile)\\b"
        },
        {
          "name": "constant.language.gecko",
          "match": "\\b(true|false|null)\\b"
        },
        {
          "name": "keyword.operator.gecko",
          "match": "\\b(as|is)\\b"
        },
        {
          "name": "keyword.other.gecko",
          "match": "\\b(self|asm)\\b"
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "entity.other.attribute-name.gecko",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "intrinsics": {
      "patterns": [
        {
          "name": "support.function.builtin.gecko",
          "match": "@(deref|size_of|is_null|read_volatile|write_volatile|align_of|type_of|transmute|unreachable|panic)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.gecko",
          "match": "\\b(int|int8|int16|int32|int64|uint|uint8|uint16|uint32|uint64|float32|float64|bool|string|void)\\b"
        },
        {
          "name": "entity.name.type.gecko",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.gecko",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        },
        {
          "name": "entity.name.function.gecko",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=<[^>]*>\\s*\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.gecko",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.arithmetic.gecko",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.logical.gecko",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.bitwise.gecko",
          "match": "(&|\\||\\^|<<|>>|~)"
        },
        {
          "name": "keyword.operator.assignment.gecko",
          "match": "(=|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=)"
        },
        {
          "name": "keyword.operator.arrow.gecko",
          "match": "(->|::)"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.gecko",
          "match": "[,;]"
        },
        {
          "name": "punctuation.bracket.gecko",
          "match": "[\\[\\]\\(\\)\\{\\}]"
        },
        {
          "name": "punctuation.accessor.gecko",
          "match": "\\."
        }
      ]
    }
  }
}
