// spec: spec/types.md, spec/functions.md, spec/modules.md, spec/control-flow.md

package llvm_parity_enum_slice

enum Color {
    Red
    Green
    Blue
}

func color_code(c: Color): int32 {
    return c as int32
}

external func main(): int32 {
    let blue: Color = Color.Blue
    let red_code: int32 = Color.Red as int32
    return color_code(blue) + red_code
}
