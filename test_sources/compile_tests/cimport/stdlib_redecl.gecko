// spec: spec/types.md, spec/functions.md, spec/modules.md, spec/c-interop.md, spec/stdlib.md

package cimport_stdlib_redecl

cimport "<stdlib.h>"
cimport "<string.h>"

import std.collections.vec use { Vec }

external func main(): int32 {
    let v: Vec<int32> = Vec<int32>::new()
    v.push(11)
    v.push(31)

    let value: int32 = v.pop()
    v.drop()

    if (value != 31) {
        return 1
    }

    return 0
}
