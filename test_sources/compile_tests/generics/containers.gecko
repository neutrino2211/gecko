package containers

class Box<T> {
    let value: T
    let valid: bool
}

class Pair<A, B> {
    let first: A
    let second: B
}

class Triple<A, B, C> {
    let a: A
    let b: B
    let c: C
}

func identity<T>(x: T): T {
    return x
}

func first<A, B>(a: A, b: B): A {
    return a
}

func second<A, B>(a: A, b: B): B {
    return b
}

func add_ints(a: int, b: int): int {
    return a + b
}

func apply<T>(f: func(T, T): T, x: T, y: T): T {
    return f(x, y)
}

external func main(): int32 {
    let box_int: Box<int>
    let box_byte: Box<uint8>
    let pair: Pair<int, uint8>
    let triple: Triple<int, int, int>
    let nested: Box<Box<int>>

    let x: int = identity<int>(10)
    let y: uint8 = identity<uint8>(20)

    let a: int = first<int, uint8>(1, 2)
    let b: uint8 = second<int, uint8>(1, 2)

    let sum: int = apply<int>(add_ints, 5, 3)

    return x + a + sum
}
