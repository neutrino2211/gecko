// spec: spec/types.md, spec/functions.md, spec/modules.md, spec/control-flow.md, spec/pointers.md

package main

declare external variardic func printf(format: string): int

func test_cast(x: int): int {
    let small: int = x as int
    return small
}

func main(): int {
    let result: int = test_cast(42)
    printf(&"Result: %d\n", result)
    return 0
}
