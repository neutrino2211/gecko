// spec: spec/types.md, spec/functions.md, spec/classes.md, spec/traits.md, spec/modules.md, spec/control-flow.md

package main

import shared

public trait Renderable {
    func render(self): int32
}

impl Renderable for Point {
    func render(self): int32 {
        return self.sum()
    }
}

external func main(): int32 {
    let p: Point = Point::new(10, 25)
    return p.render()
}
