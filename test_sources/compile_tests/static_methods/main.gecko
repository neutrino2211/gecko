package main

declare external func printf(fmt: string): int

class Counter {
    let value: int32

    // Static constructor
    func new(initial: int32): Counter {
        let c: Counter
        c.value = initial
        return c
    }

    // Instance method
    func increment(self) {
        self.value = self.value + 1
    }

    func get(self): int32 {
        return self.value
    }
}

external func main(): int32 {
    // Use static constructor
    let c: Counter = Counter::new(10)

    printf("Initial value: ")
    if (c.get() == 10) {
        printf("10 - OK\n")
    } else {
        printf("FAIL\n")
        return 1
    }

    c.increment()
    c.increment()
    c.increment()

    printf("After 3 increments: ")
    if (c.get() == 13) {
        printf("13 - OK\n")
    } else {
        printf("FAIL\n")
        return 1
    }

    return 0
}
