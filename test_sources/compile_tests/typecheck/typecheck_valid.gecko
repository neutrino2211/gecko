package typecheck

func add(a: int, b: int): int {
    return a + b
}

func greet(name: string): string {
    return name
}

func test_valid_calls(): void {
    // Valid - correct types
    let sum: int = add(10, 20)
    let greeting: string = greet("hello")

    // Valid reassignment
    let x: int = 10
    x = 20
    x = add(1, 2)
}

func main(): int {
    test_valid_calls()
    return 0
}
