package main

import std.collections.string use { StringBuilder, str_len, streq }

declare external func printf(fmt: string): int

external func main(): int32 {
    let sb: StringBuilder = StringBuilder {
        buffer: 0 as uint8*,
        length: 0,
        capacity: 0
    }

    sb.init()

    if (sb.is_empty()) {
        printf("StringBuilder is empty after init\n")
    }

    let ok: bool = sb.push_byte(72)
    ok = sb.push_byte(105)
    ok = sb.push_byte(33)

    printf("Length after push: ")
    let len: uint64 = sb.len()

    if (len == 3) {
        printf("3 (correct)\n")
    } else {
        printf("wrong\n")
        return 1
    }

    let b0: uint8 = sb.get(0)
    let b1: uint8 = sb.get(1)
    let b2: uint8 = sb.get(2)

    if (b0 == 72) {
        printf("Byte 0: H (correct)\n")
    } else {
        printf("Byte 0: wrong\n")
        return 1
    }

    if (b1 == 105) {
        printf("Byte 1: i (correct)\n")
    } else {
        printf("Byte 1: wrong\n")
        return 1
    }

    if (b2 == 33) {
        printf("Byte 2: ! (correct)\n")
    } else {
        printf("Byte 2: wrong\n")
        return 1
    }

    sb.clear()
    if (sb.is_empty()) {
        printf("StringBuilder is empty after clear\n")
    } else {
        printf("StringBuilder not empty after clear\n")
        return 1
    }

    sb.destroy()
    printf("StringBuilder freed successfully\n")

    let hello: string = "Hello"
    let hlen: uint64 = string.str_len(hello)
    if (hlen == 5) {
        printf("strlen works: 5\n")
    } else {
        printf("strlen wrong\n")
        return 1
    }

    let world: string = "World"
    let hello2: string = "Hello"

    if (string.streq(hello, hello2)) {
        printf("streq: Hello == Hello (correct)\n")
    } else {
        printf("streq failed\n")
        return 1
    }

    if (!string.streq(hello, world)) {
        printf("streq: Hello != World (correct)\n")
    } else {
        printf("streq wrong\n")
        return 1
    }

    return 0
}
