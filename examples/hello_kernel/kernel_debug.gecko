package kernel

// Minimal test - write directly to VGA
external func kmain(): void {
    // Write 'X' directly to VGA at position 0
    // VGA address 0xB8000, white on black = 0x0F, 'X' = 0x58
    let vga: uint16 volatile* = 0xB8000 as uint16 volatile*
    vga[0] = 0x0F58
    vga[1] = 0x0F59
    vga[2] = 0x0F5A

    // Halt
    asm { "cli" }
    asm { "hlt" }
}
